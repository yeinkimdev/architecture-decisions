# 모든 텍스트 파일은 저장소에 LF로 저장
* text=auto eol=lf

# 명시적으로 텍스트 파일 지정
*.md     text eol=lf
*.java   text eol=lf
*.gradle text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.xml    text eol=lf
*.sh     text eol=lf

# Windows 전용 파일은 CRLF 유지
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# 바이너리 파일은 변환 금지
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary